pipeline {
    agent any

    environment {
        REGISTRY_HOST = "192.168.49.2:30500"
        GIT_COMMIT_SHORT = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
        BRANCH_NAME = sh(script: "git rev-parse --abbrev-ref HEAD", returnStdout: true).trim()
        IMAGE_TAG = "${BRANCH_NAME}-${GIT_COMMIT_SHORT}"
    }

    options {
        timeout(time: 15, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '5'))
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                sh '''
                    echo "Branch: ${BRANCH_NAME}"
                    echo "Commit: ${GIT_COMMIT_SHORT}"
                    echo "Image tag: ${IMAGE_TAG}"
                '''
            }
        }

        stage('Build Images') {
            steps {
                sh '''
                    echo "Building Docker images..."
                    echo "Would build: ${REGISTRY_HOST}/sales-api:${IMAGE_TAG}"
                    echo "Would build: ${REGISTRY_HOST}/inventory-api:${IMAGE_TAG}"
                    echo "Would build: ${REGISTRY_HOST}/shipment-api:${IMAGE_TAG}"
                    echo "Would build: ${REGISTRY_HOST}/notification-service:${IMAGE_TAG}"
                '''
            }
        }

        stage('Push Images') {
            steps {
                sh '''
                    echo "Pushing images to registry..."
                    echo "Would push: ${REGISTRY_HOST}/sales-api:${IMAGE_TAG}"
                    echo "Would push: ${REGISTRY_HOST}/inventory-api:${IMAGE_TAG}"
                    echo "Would push: ${REGISTRY_HOST}/shipment-api:${IMAGE_TAG}"
                    echo "Would push: ${REGISTRY_HOST}/notification-service:${IMAGE_TAG}"
                '''
            }
        }

        stage('Update Manifests') {
            steps {
                sh '''
                    echo "Updating Kubernetes manifests with new image tags..."
                    echo "Argo CD will detect changes and sync automatically"
                '''
            }
        }

        stage('Trigger Deployment') {
            steps {
                sh '''
                    echo "Deployment triggered!"
                    echo "Argo CD is syncing new manifests to cluster..."
                    echo "Check Grafana to see metrics improve!"
                '''
            }
        }
    }

    post {
        success {
            echo '''
            ✅ Pipeline completed successfully!
            
            📦 Images tagged: ${IMAGE_TAG}
            🔄 Argo CD will auto-sync
            📊 Check Grafana for metrics
            '''
        }
        failure {
            echo '❌ Pipeline failed! Check logs above.'
        }
    }
}
