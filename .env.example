# ─────────────────────────────────────────────
#  BoxCo — environment variables
#  Copy this file to .env and fill in your values
#  Never commit .env to Git
# ─────────────────────────────────────────────

# Scenario (1, 2, or 3 — controls which version of
# the stock-check logic each service runs)
SCENARIO=1

# Postgres (Sales DB)
POSTGRES_USER=sales_user
POSTGRES_PASSWORD=changeme_in_production

# Notification mode
# "log"  — print notifications to console (local dev)
# "send" — actually send via Twilio + SendGrid (production)
NOTIFICATION_MODE=log

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid (email notifications)
SENDGRID_API_KEY=
